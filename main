        <form id="fA">
            <label>TÉCNICO</label>
            <select id="tecA" required>
                <option value="FRANCISCO">FRANCISCO</option>
                <option value="JUAN CAMILO">JUAN CAMILO</option>
                <option value="ANDRES FELIPE">ANDRES FELIPE</option>
