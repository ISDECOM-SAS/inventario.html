<script>
    // ⚠️ REEMPLAZA ESTA URL CON LA QUE TE DIO GOOGLE AL IMPLEMENTAR (LA QUE TERMINA EN /exec)
    const url = "https://script.google.com/macros/s/AKfycbyPF_vnJJ7-zM6u3ZNKaRaW9w0fuRsbiMDBsxjJofcyqwP9TFMTxTGiuAbN8JLKtZWc/exec";

    // Función para cambiar entre pestañas
    function tab(id) {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        document.getElementById('tab-' + id).classList.add('active');
        document.getElementById(id).classList.add('active');
    }

    // Función para cargar los datos desde la API
    async function cargar() {
        const loadStock = document.getElementById('loadStock');
        const tablasDiv = document.getElementById('tablas');
        
        loadStock.style.display = 'block';
        tablasDiv.innerHTML = '';

        try {
            const r = await fetch(url);
            const d = await r.json();

            // Renderizar Herramientas
            let html = '<h4>HERRAMIENTAS</h4><table><tr><th>CANT</th><th>DESCRIPCIÓN</th></tr>';
            if (d.herramientas && d.herramientas.length > 0) {
                d.herramientas.forEach(f => {
                    let colorClass = f[0] > 0 ? 'badge-v' : 'badge-r';
                    html += `<tr><td><span class="badge ${colorClass}">${f[0]}</span></td><td>${f[1]}</td></tr>`;
                });
            } else {
                html += '<tr><td colspan="2">SIN DATOS</td></tr>';
            }
            html += '</table>';

            // Renderizar Accesorios
            html += '<h4>ACCESORIOS</h4><table><tr><th>CANT</th><th>EQUIPO</th><th>SERIAL</th></tr>';
            if (d.accesorios && d.accesorios.length > 0) {
                d.accesorios.forEach(f => {
                    let colorClass = f[0] > 0 ? 'badge-v' : 'badge-r';
                    html += `<tr><td><span class="badge ${colorClass}">${f[0]}</span></td><td>${f[1]} ${f[2] || ''}</td><td>${f[3] || 'S/N'}</td></tr>`;
                });
            } else {
                html += '<tr><td colspan="3">SIN DATOS</td></tr>';
            }
            html += '</table>';

            tablasDiv.innerHTML = html;
        } catch(e) {
            tablasDiv.innerHTML = '<p style="color:red; text-align:center;">ERROR AL CONECTAR CON LA API</p>';
            console.error(e);
        } finally {
            loadStock.style.display = 'none';
        }
    }

    // Guardar Herramientas
    document.getElementById('fH').onsubmit = async (e) => {
        e.preventDefault();
        const loader = document.getElementById('lH');
        const btn = document.getElementById('btnH');
        
        loader.style.display = 'block';
        btn.style.display = 'none';

        let cant = parseInt(document.getElementById('canH').value);
        if(document.getElementById('opH').value === 'retiro') cant = -Math.abs(cant);
        
        const payload = { 
            tipo: "herramientas", 
            herramienta: document.getElementById('nomH').value, 
            cantidad: cant, 
            tecnico: document.getElementById('tecH').value 
        };
        
        await enviar(payload, 'fH', 'lH', 'btnH');
    };

    // Guardar Accesorios
    document.getElementById('fA').onsubmit = async (e) => {
        e.preventDefault();
        const loader = document.getElementById('lA');
        const btn = document.getElementById('btnA');

        loader.style.display = 'block';
        btn.style.display = 'none';

        let cant = parseInt(document.getElementById('canA').value);
        if(document.getElementById('opA').value === 'retiro') cant = -Math.abs(cant);

        const payload = { 
            tipo: "accesorios", 
            marca: document.getElementById('marA').value, 
            modelo: "", 
            serial: document.getElementById('serA').value, 
            cantidad: cant, 
            precioCompra: document.getElementById('pcA').value, 
            precioVenta: document.getElementById('pvA').value,
            tecnico: document.getElementById('tecA').value 
        };
        
        await enviar(payload, 'fA', 'lA', 'btnA');
    };

    // Función universal para enviar datos (POST)
    async function enviar(p, fId, lId, bId) {
        try {
            const resp = await fetch(url, { 
                method: 'POST', 
                mode: 'no-cors', // Necesario para evitar bloqueos de navegador en redirecciones de Google
                body: JSON.stringify(p) 
            });
            
            alert("✅ REGISTRO PROCESADO CON ÉXITO");
            document.getElementById(fId).reset();
            cargar();
            tab('stock');
        } catch(e) {
            alert("❌ ERROR AL GUARDAR");
            console.error(e);
        } finally {
            document.getElementById(lId).style.display = 'none';
            document.getElementById(bId).style.display = 'block';
        }
    }

    // Cargar automáticamente al iniciar
    window.onload = cargar;
</script>

</body>
</html>
