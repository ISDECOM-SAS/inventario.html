<script>
    // URL DE LA API DE INVENTARIO (GAS)
    const url = "https://script.google.com/macros/s/AKfycbySK62_y4VEmkkLuBym19EejaQm6Q8z9tMxrWE_scpoYxhy2n1R7tpeNdX_Kt4ymd0lLQ/exec";

    function tab(id) {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        document.getElementById('btn-' + id).classList.add('active');
        document.getElementById(id).classList.add('active');
    }

    async function cargar() {
        const loader = document.getElementById('loadStock');
        const tablas = document.getElementById('tablas');
        loader.style.display = 'block';
        tablas.innerHTML = '';

        try {
            const r = await fetch(url);
            const d = await r.json();

            let h = '<h4>HERRAMIENTAS / INSUMOS</h4><table><tr><th>CANT</th><th>DESCRIPCIÓN</th></tr>';
            d.herramientas.forEach(fila => {
                let cl = fila[0] > 0 ? 'badge-v' : 'badge-r';
                h += `<tr><td><span class="badge ${cl}">${fila[0]}</span></td><td>${fila[1]}</td></tr>`;
            });
            h += '</table><h4>ACCESORIOS / EQUIPOS</h4><table><tr><th>CANT</th><th>DETALLE</th><th>SERIAL</th></tr>';
            d.accesorios.forEach(fila => {
                let cl = fila[0] > 0 ? 'badge-v' : 'badge-r';
                h += `<tr><td><span class="badge ${cl}">${fila[0]}</span></td><td>${fila[1]} ${fila[2] || ''}</td><td>${fila[3] || ''}</td></tr>`;
            });
            tablas.innerHTML = h + '</table>';
        } catch(e) { tablas.innerHTML = '<p style="color:red;text-align:center">ERROR DE CONEXIÓN</p>'; }
        loader.style.display = 'none';
    }

    document.getElementById('fH').onsubmit = async (e) => {
        e.preventDefault();
        document.getElementById('lH').style.display = 'block';
        document.getElementById('btnH').style.display = 'none';
        let cant = parseInt(document.getElementById('canH').value);
        if(document.getElementById('opH').value === 'retiro') cant = -Math.abs(cant);
        const p = { tipo: "herramientas", herramienta: document.getElementById('nomH').value, cantidad: cant, tecnico: document.getElementById('tecH').value };
        await enviar(p, 'fH', 'lH', 'btnH');
    };

    document.getElementById('fA').onsubmit = async (e) => {
        e.preventDefault();
        document.getElementById('lA').style.display = 'block';
        document.getElementById('btnA').style.display = 'none';
        let cant = parseInt(document.getElementById('canA').value);
        if(document.getElementById('opA').value === 'retiro') cant = -Math.abs(cant);
        const p = { tipo: "accesorios", marca: document.getElementById('marA').value, serial: document.getElementById('serA').value, cantidad: cant, tecnico: document.getElementById('tecA').value };
        await enviar(p, 'fA', 'lA', 'btnA');
    };

    async function enviar(p, fId, lId, bId) {
        try {
            await fetch(url, { method: 'POST', mode: 'no-cors', body: JSON.stringify(p) });
            alert("REGISTRO EXITOSO");
            document.getElementById(fId).reset();
            cargar();
            tab('stock');
        } catch(e) { alert("ERROR AL GUARDAR"); }
        document.getElementById(lId).style.display = 'none';
        document.getElementById(bId).style.display = 'block';
    }
    window.onload = cargar;
</script>
