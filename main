<script>
    const url = "https://script.google.com/macros/s/AKfycbzJqfE6F7viZhuRq5y28Ht9-MhL9kOp2TG5lgH9FnUn5AzdTEKgKtehp00S7zwxN6Io4g/exec";

    function tab(id) {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        event.currentTarget.classList.add('active');
        document.getElementById(id).classList.add('active');
    }

    async function cargar() {
        document.getElementById('loadStock').style.display = 'block';
        document.getElementById('tablas').innerHTML = '';
        try {
            const r = await fetch(url);
            const d = await r.json();
            let h = '<h4>HERRAMIENTAS</h4><table><tr><th>CANT</th><th>NOMBRE</th></tr>';
            d.herramientas.forEach(f => {
                let cl = f[0] > 0 ? 'badge-v' : 'badge-r';
                h += `<tr><td><span class="badge ${cl}">${f[0]}</span></td><td>${f[1]}</td></tr>`;
            });
            h += '</table><h4 style="margin-top:20px">ACCESORIOS</h4><table><tr><th>CANT</th><th>INFO</th><th>SERIAL</th></tr>';
            d.accesorios.forEach(f => {
                let cl = f[0] > 0 ? 'badge-v' : 'badge-r';
                h += `<tr><td><span class="badge ${cl}">${f[0]}</span></td><td>${f[1]} ${f[2]}</td><td>${f[3]}</td></tr>`;
            });
            document.getElementById('tablas').innerHTML = h + '</table>';
        } catch(e) { alert("Error cargando datos"); }
        document.getElementById('loadStock').style.display = 'none';
    }

    document.getElementById('fH').onsubmit = async (e) => {
        e.preventDefault();
        document.getElementById('lH').style.display = 'block';
        document.getElementById('btnH').style.display = 'none';
        let cant = parseInt(document.getElementById('canH').value);
        if(document.getElementById('opH').value === 'retiro') cant = -Math.abs(cant);
        
        const payload = { tipo: "herramientas", herramienta: document.getElementById('nomH').value, cantidad: cant, tecnico: document.getElementById('tecH').value };
        await enviar(payload, 'fH', 'lH', 'btnH');
    };

    document.getElementById('fA').onsubmit = async (e) => {
        e.preventDefault();
        document.getElementById('lA').style.display = 'block';
        document.getElementById('btnA').style.display = 'none';
        let cant = parseInt(document.getElementById('canA').value);
        if(document.getElementById('opA').value === 'retiro') cant = -Math.abs(cant);

        const payload = { 
            tipo: "accesorios", marca: document.getElementById('marA').value, modelo: "", 
            serial: document.getElementById('serA').value, cantidad: cant, 
            precioCompra: document.getElementById('pcA').value, precioVenta: document.getElementById('pvA').value,
            tecnico: document.getElementById('tecA').value 
        };
        await enviar(payload, 'fA', 'lA', 'btnA');
    };

    async function enviar(p, fId, lId, bId) {
        try {
            await fetch(url, { method: 'POST', body: JSON.stringify(p) });
            alert("REGISTRO EXITOSO");
            document.getElementById(fId).reset();
            cargar();
            tab('stock');
        } catch(e) { alert("ERROR AL GUARDAR"); }
        document.getElementById(lId).style.display = 'none';
        document.getElementById(bId).style.display = 'block';
    }

    window.onload = cargar;
</script>
</body>
