<script>
    // =========================================================
    // 🔗 PEGA AQUÍ TU NUEVO ENLACE DE APPS SCRIPT DE INVENTARIO
    // =========================================================
    const apiURL = "https://script.google.com/macros/s/AKfycbxKMNJiU367N0PJcXhhr14jzcccGUNiKpSv_tv9AHmF48DrxjQJs8NTwGZSmuHYPs1WgQ/exeC";

    function cambiarPestana(sección) {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('activa'));
        document.querySelectorAll('.seccion-formulario').forEach(s => s.classList.remove('activa'));
        
        const tabsMap = { 'consulta': 0, 'herramientas': 1, 'accesorios': 2 };
        document.querySelectorAll('.tab')[tabsMap[seccion]].classList.add('activa');
        document.getElementById('seccion' + sección.charAt(0).toUpperCase() + sección.slice(1)).classList.add('activa');
    }

    document.addEventListener("DOMContentLoaded", () => { cargarInventario(); });

    función cargarInventario() {
        if(apiURL === "PEGAR_AQUI_TU_NUEVO_ENLACE_DE_APPS_SCRIPT") { retorno; }

        document.getElementById("loaderConsulta").style.display = "block";
        document.getElementById("contenidoInventario").style.display = "none";

        fetch(apiURL).then(r => r.json()).then(data => {
            renderTabla("tablaHerramientas", data.herramientas, "herramientas");
            renderTabla("tablaAccesorios", data.accesorios, "accesorios");
            
            // ✅ CARGAR EL DESPLEGABLE INTELIGENTE DE HERRAMIENTAS
            const datalist = document.getElementById("listaHerramientas");
            datalist.innerHTML = "";
            if(datos.herramientas && datos.herramientas.longitud > 0) {
                datos.herramientas.forEach(f => {
                    if(f[1]) datalist.innerHTML += `<option value="${f[1]}">`;
                });
            }

            document.getElementById("loaderConsulta").style.display = "none";
            document.getElementById("contenidoInventario").style.display = "block";
        }).catch(e => {
            document.getElementById("loaderConsulta").innerText = "❌ ERROR DE CONEXIÓN.";
        });
    }

    function renderTabla(idTabla, filas, tipo) {
        const tbody = document.querySelector(`#${idTabla} tbody`);
        tbody.innerHTML = ""; 

        if (!filas || filas.length === 0) {
            tbody.innerHTML = `<tr><td colspan="4" style="text-align:center;">No hay registros disponibles.</td></tr>`; return;
        }

        filas.forEach(fila => {
            let cantidad = parseInt(fila[0]);
            let claseBadge = cantidad > 0 ? "badge-verde" : (cantidad < 0 ? "badge-rojo" : "");
            let insignia = `<span class="cantidad-badge ${claseBadge}">${cantidad}</span>`;

            let tr = document.createElement("tr");
            if (tipo === "herramientas") {
                tr.innerHTML = `<td>${badge}</td><td>${fila[1]}</td>`;
            } demás {
                let pVentaFormat = new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(fila[5] || 0);
                tr.innerHTML = `<td>${badge}</td><td><b>${fila[1]}</b><br>${fila[2]}</td><td>${fila[3]}</td><td>${pVentaFormat}</td>`;
            }
            tbody.appendChild(tr);
        });
    }

    function procesarFormulario(tipo, payload, idFormulario, letraId) {
        document.getElementById(`loader${letraId}`).style.display = 'block';
        document.getElementById(`btnEnviar${letraId}`).style.display = 'none';
        
        fetch(apiURL, { method: 'POST', headers: { 'Content-Type': 'text/plain' }, body: JSON.stringify(payload) })
        .then(r => r.json()).then(res => {
            alert(`✅ INVENTARIO ACTUALIZADO CON ÉXITO.`);
            document.getElementById(idFormulario).reset();
            document.getElementById(`loader${letraId}`).style.display = 'none';
            document.getElementById(`btnEnviar${letraId}`).style.display = 'block';
            cambiarPestana('consulta'); cargarInventario();
        }).catch(err => {
            alert("❌ ERROR AL CONECTAR CON EL SERVIDOR.");
            document.getElementById(`loader${letraId}`).style.display = 'none';
            document.getElementById(`btnEnviar${letraId}`).style.display = 'block';
        });
    }

    document.getElementById("formHerramientas").addEventListener("enviar", (e) => {
        e.preventDefault();
        let operación = document.querySelector('input[name="operacionH"]:checked').value;
        let cantidadIngresada = parseInt(document.getElementById("cantidadH").value);
        if (operacion === "retiro") cantidadIngresada = -Math.abs(cantidadIngresada); 

        let payload = { tipo: "herramientas", herramienta: document.getElementById("nombreH").value, cantidad: cantidadIngresada };
        procesarFormulario("herramientas", payload, "formHerramientas", "H");
    });

    document.getElementById("formAccesorios").addEventListener("submit", (e) => {
        e.preventDefault();
        let operacion = document.querySelector('input[nombre="operacionA"]:checked').value;
        let cantidadIngresada = parseInt(document.getElementById("cantidadA").value);
        if (operacion === "retiro") cantidadIngresada = -Math.abs(cantidadIngresada); 

        let payload = { tipo: "accesorios", marca: document.getElementById("marcaA").value, modelo: document.getElementById("modeloA").value, serial: document.getElementById("serialA").value, cantidad: cantidadIngresada, precioCompra: document.getElementById("pCompraA").value, precioVenta: document.getElementById("pVentaA").value };
        procesarFormulario("accesorios", payload, "formAccesorios", "A");
    });
</script>
</body>
